@model BridCare.Models.Shift

@{
	ViewData["Title"] = "Details";
}

<h1>Detalhes</h1>

<div>
	<h4>Plantão - <a asp-action="Shifts">Voltar a Lista</a></h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Institution.Name)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Institution.Name)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.StartTime)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.StartTime)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.EndTime)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.EndTime)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Price)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Price)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.ElderlyQuantity)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.ElderlyQuantity)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.NursingKnowledgeRequired)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.NursingKnowledgeRequired)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.CaregiversPerShift)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.CaregiversPerShift)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Description)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Description)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.CreatedAt)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.CreatedAt)
		</dd>
	</dl>
</div>
<div class="mb-3">
	<form asp-action="Apply" method="post">
		@Html.AntiForgeryToken()
		<input type="hidden" name="id" value="@Model.Id" />
		<button type="submit" class="btn btn-primary">Aplicar</button>
	</form>
</div>