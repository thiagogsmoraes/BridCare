@model Cuidado.Models.ViewModels.RegisterViewModel
@using Cuidado.Models.Enums

@{
    ViewData["Title"] = "Cadastro";
}

<div class="container py-5" style="max-width: 700px;">

    <div class="mb-4">
        <h2 class="fw-bold">Criar conta</h2>
        <p class="text-muted">Preencha os dados abaixo para se cadastrar na plataforma.</p>
    </div>

    <form asp-action="Create" method="post">
        @* Token de segurança anti-CSRF — obrigatório pro [ValidateAntiForgeryToken] funcionar *@
        @Html.AntiForgeryToken()

        @* Mostra erros gerais de validação *@
        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

        {{!-- SEÇÃO 1: Dados de acesso --}}
        <div class="card mb-4">
            <div class="card-header fw-semibold">Dados de acesso</div>
            <div class="card-body">

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" placeholder="seu@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label">Tipo de conta</label>
                    <select asp-for="Role" class="form-select" id="roleSelect">
                        <option value="">-- Selecione --</option>
                        <option value="0">Cuidador</option>
                        <option value="1">Instituição</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

            </div>
        </div>

        {{!-- SEÇÃO 2: Dados do Cuidador (aparece só se Role = Caregiver) --}}
        <div class="card mb-4 d-none" id="caregiverSection">
            <div class="card-header fw-semibold">Dados do Cuidador</div>
            <div class="card-body">

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Nome completo</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CPF" class="form-label">CPF</label>
                        <input asp-for="CPF" class="form-control" placeholder="000.000.000-00" />
                        <span asp-validation-for="CPF" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BirthDate" class="form-label">Data de nascimento</label>
                        <input asp-for="BirthDate" type="date" class="form-control" />
                        <span asp-validation-for="BirthDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">Gênero</label>
                        <select asp-for="Gender" class="form-select"
                                asp-items="Html.GetEnumSelectList<Gender>()">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Telefone</label>
                        <input asp-for="Phone" class="form-control" placeholder="(00) 00000-0000" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Adress" class="form-label">Endereço</label>
                    <input asp-for="Adress" class="form-control" />
                    <span asp-validation-for="Adress" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="EducationLevel" class="form-label">Escolaridade</label>
                        <select asp-for="EducationLevel" class="form-select"
                                asp-items="Html.GetEnumSelectList<EducationLevel>()">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="EducationLevel" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ExpectedSalary" class="form-label">Pretensão salarial (R$)</label>
                        <input asp-for="ExpectedSalary" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="ExpectedSalary" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Sobre você <span class="text-muted">(opcional)</span></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Conte sua experiência, diferenciais..."></textarea>
                </div>

            </div>
        </div>

        {{!-- SEÇÃO 3: Dados da Instituição (aparece só se Role = Institution) --}}
        <div class="card mb-4 d-none" id="institutionSection">
            <div class="card-header fw-semibold">Dados da Instituição</div>
            <div class="card-body">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nome da instituição</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cnpj" class="form-label">CNPJ</label>
                        <input asp-for="Cnpj" class="form-control" placeholder="00.000.000/0000-00" />
                        <span asp-validation-for="Cnpj" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="InstitutionType" class="form-label">Tipo</label>
                        <select asp-for="InstitutionType" class="form-select"
                                asp-items="Html.GetEnumSelectList<Category>()">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="InstitutionType" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="InstitutionPhone" class="form-label">Telefone</label>
                        <input asp-for="InstitutionPhone" class="form-control" placeholder="(00) 0000-0000" />
                        <span asp-validation-for="InstitutionPhone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Whatsapp" class="form-label">WhatsApp</label>
                        <input asp-for="Whatsapp" class="form-control" placeholder="(00) 00000-0000" />
                        <span asp-validation-for="Whatsapp" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="InstitutionEmail" class="form-label">E-mail da instituição</label>
                    <input asp-for="InstitutionEmail" class="form-control" />
                    <span asp-validation-for="InstitutionEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="InstitutionAdress" class="form-label">Endereço</label>
                    <input asp-for="InstitutionAdress" class="form-control" />
                    <span asp-validation-for="InstitutionAdress" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="InstitutionDescription" class="form-label">Descrição</label>
                    <textarea asp-for="InstitutionDescription" class="form-control" rows="3"
                              placeholder="Descreva a instituição, missão, estrutura..."></textarea>
                </div>

            </div>
        </div>

        {{!-- BOTÕES --}}
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Cadastrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>

    </form>
</div>

@section Scripts {
    @* Validação client-side do ASP.NET (jquery.validate) *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Pega o select de Role
        const roleSelect = document.getElementById('roleSelect');
        const caregiverSection = document.getElementById('caregiverSection');
        const institutionSection = document.getElementById('institutionSection');

        roleSelect.addEventListener('change', function () {
            const val = this.value;

            // Esconde os dois primeiro
            caregiverSection.classList.add('d-none');
            institutionSection.classList.add('d-none');

            // Mostra o correto
            if (val === '0') caregiverSection.classList.remove('d-none');
            if (val === '1') institutionSection.classList.remove('d-none');
        });
    </script>
}