@model Cuidado.Models.Elderly
@using Cuidado.Models.Enums

@{
    ViewData["Title"] = "Cadastrar Idoso";
}

<div class="container py-5" style="max-width: 500px;">

    <div class="mb-4">
        <h2 class="fw-bold">@ViewData["Title"]</h2>
        <p class="text-muted">Preencha os dados abaixo para cadastrar o idoso.</p>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        @* Campo oculto — preenchido automaticamente pelo ViewBag *@
        <input type="hidden" asp-for="InstitutionId" value="@ViewBag.InstitutionId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

        <div class="card mb-4">
            <div class="card-header fw-semibold">Dados do Idoso</div>
            <div class="card-body">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nome completo</label>
                    <input asp-for="Name" class="form-control" placeholder="Nome do idoso" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BirthDate" class="form-label">Data de nascimento</label>
                    <input asp-for="BirthDate" type="date" class="form-control" />
                    <span asp-validation-for="BirthDate" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">Gênero</label>
                        <select asp-for="Gender" class="form-select"
                                asp-items="Html.GetEnumSelectList<Gender>()">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Condition" class="form-label">Condição</label>
                        <select asp-for="Condition" class="form-select"
                                asp-items="Html.GetEnumSelectList<Condition>()">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="Condition" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Notas <span class="text-muted">(Cuidados especiais)</span></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="Observações relevantes sobre o idoso..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Cadastrar</button>
            <a asp-action="Index" asp-route-id="@ViewBag.InstitutionId"
               class="btn btn-outline-secondary">Cancelar</a>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}